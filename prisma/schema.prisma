generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Produit {
  id    Int    @id @default(autoincrement())
  nom   String
  prix  Float
  stock Int    @default(10)
}

// =====================
// MODIF MODEL COMMANDE
// =====================

model Commande {
  id        Int      @id @default(autoincrement())
  nom       String
  email     String
  telephone String
  adresse   String
  total     Float
  produits  String?

  // 🔥 AJOUTS
  statut    String   @default("EN_ATTENTE")
  paiement  String   @default("WERO")

  createdAt DateTime @default(now())
}